<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_subtask_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#111827"
    android:padding="8dp"
    android:layout_marginTop="1dp"
    android:layout_marginBottom="1dp"
    android:layout_marginStart="28dp"
    android:layout_marginEnd="4dp"
    android:gravity="center_vertical">

    <!-- Indentation indicator line -->
    <FrameLayout
        android:layout_width="2dp"
        android:layout_height="14dp"
        android:background="#475569"
        android:layout_marginEnd="8dp" />

    <!-- Subtask Checkbox -->
    <FrameLayout
        android:id="@+id/subtask_checkbox_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="2dp"
        android:layout_marginEnd="6dp">

        <ImageView
            android:id="@+id/subtask_checkbox"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_checkbox_unchecked"
            android:contentDescription="Erledigen" />
    </FrameLayout>

    <!-- Subtask Title -->
    <TextView
        android:id="@+id/subtask_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="#E2E8F0"
        android:textSize="12sp"
        android:autoLink="web"
        android:textColorLink="#C5A059"
        android:textColorHighlight="#33C5A059"
        android:maxLines="6"
        android:layout_gravity="center_vertical" />

    <!-- Gear/Settings Button Container for subtask -->
    <FrameLayout
        android:id="@+id/subtask_edit_button_container"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="4dp"
        android:layout_gravity="center_vertical">

        <ImageView
            android:id="@+id/subtask_edit_button"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_settings"
            android:contentDescription="Bearbeiten" />
    </FrameLayout>
</LinearLayout>
