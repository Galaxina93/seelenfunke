<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_tasks_add_list_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1E293B"
    android:padding="12dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="6dp"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NEUE LISTE ERSTELLEN"
        android:textColor="#C5A059"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#334155"
        android:layout_marginBottom="10dp" />

    <!-- Name Input Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="Name:"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_add_list_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start|center_vertical"
            android:text="[Tippen zum Schreiben]"
            android:textSize="12sp"
            android:textColor="#F8FAFC"
            android:padding="8dp"
            android:background="#0F172A" />
    </LinearLayout>

    <!-- Save & Cancel Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btn_add_list_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="ABBRECHEN"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#94A3B8"
            android:background="#334155"
            android:padding="8dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/btn_add_list_save"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="SPEICHERN"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#030712"
            android:background="#C5A059"
            android:padding="8dp" />
    </LinearLayout>
</LinearLayout>
