<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".SeelenfunkeApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Seelenfunke"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Seelenfunke"
        android:usesCleartextTraffic="true">
        
        <service
            android:name=".services.WakeWordService"
            android:foregroundServiceType="microphone"
            android:exported="false" />

        <service
            android:name=".services.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>


        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:label="Seelenfunke"
            android:theme="@style/Theme.Seelenfunke"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|keyboard|navigation|locale|layoutDirection|fontScale|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="de.meinseelenfunke.app.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <receiver
            android:name=".widget.CalendarAppWidgetProvider"
            android:exported="true"
            android:label="Seelenfunke Kalender">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/calendar_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.CalendarMonthWidgetProvider"
            android:exported="true"
            android:label="Seelenfunke Monatskalender">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_PREV_MONTH" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_NEXT_MONTH" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_RESET_MONTH" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_SELECT_DAY" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_SHOW_MONTH" />

            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/calendar_month_widget_info" />
        </receiver>

        <service
            android:name=".widget.CalendarWidgetService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

        <receiver
            android:name=".widget.ShoppingListWidgetProvider"
            android:exported="true"
            android:label="Seelenfunke Einkaufsliste">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_SHOPPING_REFRESH" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_SHOPPING_TOGGLE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_shopping_info" />
        </receiver>

        <service
            android:name=".widget.ShoppingListWidgetService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

        <receiver
            android:name=".widget.TasksWidgetProvider"
            android:exported="true"
            android:label="Seelenfunke Aufgaben">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_TASKS_REFRESH" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_TASKS_SELECT_LIST" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_TASKS_BACK" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_TASKS_TOGGLE" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_TASKS_CYCLE_PRIORITY" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_TASKS_CYCLE_DATE" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_TASKS_EDIT" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_TASKS_EXIT_EDIT_MODE" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_TASKS_SET_PRIORITY" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_TASKS_CLEAR_DATE" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_TASKS_ADD_SUBTASK" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_TASKS_CANCEL_ADD_SUBTASK" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_TASKS_SAVE_ADD_SUBTASK" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_TASKS_DELETE_LIST" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_TASKS_DELETE_TASK" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_TASKS_ADD_LIST_CLICK" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_TASKS_ADD_TASK_CLICK" />
                <action android:name="de.meinseelenfunke.app.widget.ACTION_TASKS_NONE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_tasks_info" />
        </receiver>

        <service
            android:name=".widget.TasksWidgetService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

        <activity
            android:name=".widget.AddShoppingItemActivity"
            android:theme="@style/Theme.TransparentDialog"
            android:exported="false"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <activity
            android:name=".widget.EditTaskWidgetActivity"
            android:theme="@style/Theme.TransparentDialog"
            android:exported="false"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <activity
            android:name=".widget.AddTaskWidgetActivity"
            android:theme="@style/Theme.TransparentDialog"
            android:exported="false"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <activity
            android:name=".widget.AddSubtaskWidgetActivity"
            android:theme="@style/Theme.TransparentDialog"
            android:exported="false"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <activity
            android:name=".widget.AddTaskListWidgetActivity"
            android:theme="@style/Theme.TransparentDialog"
            android:exported="false"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <activity
            android:name=".widget.ConfirmDeleteListActivity"
            android:theme="@style/Theme.TransparentDialog"
            android:exported="false"
            android:taskAffinity=""
            android:excludeFromRecents="true" />


        <activity
            android:name=".widget.TextInputActivity"
            android:theme="@style/Theme.TransparentDialog"
            android:exported="false"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <activity
            android:name=".widget.DatePickerActivity"
            android:theme="@style/Theme.TransparentDialog"
            android:exported="false"
            android:taskAffinity=""
            android:excludeFromRecents="true" />

        <receiver
            android:name=".receiver.CalendarAlarmReceiver"
            android:exported="false" />

        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
